# syntax=docker/dockerfile:1
#
# Development image for Recast MCP Rust services.
# Includes cargo-watch for hot reload on source file changes.
#
# Used by docker/docker-compose.override.yml — NOT for production builds.

FROM rust:1.85-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends pkg-config libssl-dev curl \
    && rm -rf /var/lib/apt/lists/* \
    && cargo install cargo-watch --locked

WORKDIR /app
